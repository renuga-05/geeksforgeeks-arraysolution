
class Solution {
    public static int maxProduct(int[] arr) {
        int max1 = -1;
        int max2 = -1;
        for(int i=0;i<arr.length;i++){
            if(arr[i]>max1){
                max2 = max1;
                max1 = arr[i];
            }else if(arr[i]>max2){
                max2 = arr[i];
            }
        }
        int product= max1*max2;
        return product;
    }
}
