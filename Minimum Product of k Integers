
class Solution {

    int minProduct(int arr[], int k) {
        Arrays.sort(arr);

        long result = 1;
        long mod = 1000000007;

        int n = arr.length;

        for (int i = 0; i < Math.min(k, n); i++) {
            result = (result * arr[i]) % mod;
        }

        return (int) result;
    }
}
