class Solution {
    int missingNumber(int arr[]) {
        int n = arr.length + 1;   // because one number is missing
        
        int expectedSum = n * (n + 1) / 2;
        int actualSum = 0;
        
        for(int i = 0; i < arr.length; i++) {
            actualSum += arr[i];
        }
        
        return expectedSum - actualSum;
    }
}
