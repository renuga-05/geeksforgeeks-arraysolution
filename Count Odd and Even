class Solution {
    public int[] countOddEven(int[] arr) {
        int oddcount =0;
        int evencount =0;
        for(int i=0;i<arr.length;i++){
            int num = arr[i];
            if(num%2==0){
                evencount++;
            }else{
                oddcount++;
            }
        }
        return new int[]{oddcount, evencount};
    }
}
