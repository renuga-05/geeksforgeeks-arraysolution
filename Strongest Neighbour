class Solution {
    public ArrayList<Integer> maxAdj(int[] arr) {
        ArrayList<Integer> res = new ArrayList<Integer>();
        int n = arr.length;
        for(int i=0;i<n-1;i++){
                int max = Math.max(arr[i], arr[i+1]);
                res.add(max);
            
        }
        return res;
    }
};
