class Solution {
    public int multiply(int[] arr) {
        
        int n = arr.length;
        int mid ;
        if(n%2==0){
            mid = n/2;
        }else{
            mid = (n/2);
        }
        long leftsum =0;
        long rightsum =0;
        for(int i=0;i<mid;i++){
            leftsum+=arr[i];
        }
        for(int i=mid;i<n;i++){
            rightsum+=arr[i];
        }
         return (int)(leftsum*rightsum);
        
        
    }
}
