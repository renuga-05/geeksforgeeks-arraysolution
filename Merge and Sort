class Solution {
    public ArrayList<Integer> mergeNsort(int[] arr1, int[] arr2) {
    
        TreeSet<Integer> set = new TreeSet<>();
        
        // Add all elements from arr1
        for (int num : arr1) {
            set.add(num);
        }
        
        // Add all elements from arr2
        for (int num : arr2) {
            set.add(num);
        }
        
        // Convert TreeSet to ArrayList and return
        return new ArrayList<>(set);
    }
    
}
